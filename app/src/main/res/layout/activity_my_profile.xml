<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    tools:context=".MyProfileActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="50dp"
        android:paddingEnd="14dp"
        android:paddingBottom="24dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@android:color/transparent"
                android:src="@drawable/arrow_left" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/yeonsung_regular"
                android:text="My Profile"
                android:textColor="@color/black"
                android:textSize="28sp" />
        </LinearLayout>

        <!-- PROFILE CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/cardgreen"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="22dp">

                <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="62dp"
android:scaleType="centerCrop"
                    android:layout_height="62dp"
                    android:src="@drawable/user"
                     />

                <!-- NAME -->
                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/yeonsung_regular"
                    android:text="Rahul Sharma"
                    android:textColor="@color/black"
                    android:textSize="24sp" />

                <!-- STATUS -->
                <EditText
                    android:id="@+id/etZone"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/edittext_bg"
                    android:hint="Enter Address"
                    android:padding="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- INPUT CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/lato_bold"
                        android:text="Profile Details"
                        android:textColor="@color/black"
                        android:textSize="17sp"/>

                    <ImageButton
                        android:id="@+id/btnEditProfile"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/edit_off" />
                </LinearLayout>

                <!-- PHONE -->
                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/edittext_bg"
                    android:hint="Phone Number"
                    android:padding="12dp"
                    android:inputType="phone"/>

                <!-- VEHICLE -->
                <EditText
                    android:id="@+id/etVehicle"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/edittext_bg"
                    android:hint="Vehicle Number"
                    android:padding="12dp"/>

                <!-- LICENSE -->
                <EditText
                    android:id="@+id/etLicense"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/edittext_bg"
                    android:hint="License ID"
                    android:padding="12dp"/>

                <!-- UPLOAD -->
                <TextView
                    android:id="@+id/uploadLicense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/delivery_status_chip"
                    android:fontFamily="@font/lato_bold"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Upload License"
                    android:textColor="@color/green" />
                <TextView
                    android:id="@+id/uploaRC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/delivery_status_chip"
                    android:fontFamily="@font/lato_bold"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Upload RC"
                    android:textColor="@color/green" />
                <TextView
                    android:id="@+id/uploaAadhar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/delivery_status_chip"
                    android:fontFamily="@font/lato_bold"
                    android:gravity="center"
                    android:padding="12dp"
                    android:text="Upload Aadhar Card"
                    android:textColor="@color/green" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SAVE BUTTON (ADDED) -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Save Profile"
            android:backgroundTint="@color/green"
            android:textColor="@color/white"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="3dp"/>
    </LinearLayout>
</ScrollView>